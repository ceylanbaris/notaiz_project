# Database
DATABASE_URL=postgresql://notaiz:notaiz123@db:5432/notaiz

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Security — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth — get these from console.cloud.google.com
# 1. Create a project, enable "Google Identity API"
# 2. Credentials > Create OAuth 2.0 Client ID (Web application)
# 3. Authorized JS origins: http://localhost:3000
# 4. Authorized redirect URIs: not needed for ID-token flow
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File handling
UPLOAD_DIR=/tmp/notaiz/uploads
MAX_FILE_SIZE_MB=50
